# Unified Iraq Business Directory Scraper - Web Dashboard

# Frontend Environment Variables (exposed to browser)
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Note: ANTHROPIC_API_KEY and GOOGLE_PLACES_API_KEY are now stored server-side
# in Vercel Environment Variables for security (see vercel.json)
# Do NOT add them here - they won't be used by the frontend anymore

# Backend Environment Variables (for Vercel Functions - set in Vercel Dashboard)
# SUPABASE_URL=your_supabase_url
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# ANTHROPIC_API_KEY=your_anthropic_key_optional
# GOOGLE_PLACES_API_KEY=your_google_places_key_optional
