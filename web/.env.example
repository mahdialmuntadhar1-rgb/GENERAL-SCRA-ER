# GENERAL-SCRA-ER/web (internal scraper dashboard frontend)
#
# This dashboard is internal scraper/staging/review tooling.
# Use scraper/internal Supabase credentials only.
# Do NOT reuse belive public app env variables in this file.

# Frontend (browser-exposed)
VITE_SCRAPER_SUPABASE_URL=https://your-scraper-project-ref.supabase.co
VITE_SCRAPER_SUPABASE_ANON_KEY=your_scraper_supabase_anon_key

# Legacy frontend fallback names (supported for compatibility)
# VITE_SUPABASE_URL=https://your-scraper-project-ref.supabase.co
# VITE_SUPABASE_ANON_KEY=your_scraper_supabase_anon_key

# Server-side (set in Vercel/hosting environment)
# SCRAPER_SUPABASE_URL=https://your-scraper-project-ref.supabase.co
# SCRAPER_SUPABASE_SERVICE_ROLE_KEY=your_scraper_service_role_key
# SCRAPER_SUPABASE_ANON_KEY=your_scraper_supabase_anon_key
# ANTHROPIC_API_KEY=optional
# GOOGLE_PLACES_API_KEY=optional
