# Supabase Configuration - Required for database connection
# Get these from your Supabase Dashboard → Project Settings → API
# NOTE: Use your own private Supabase project, NOT the public "belive" database
SCRAPER_SUPABASE_URL=https://your-project-id.supabase.co
SCRAPER_SUPABASE_KEY=your-anon-or-service-role-key-here

# Legacy environment variable names (still supported for backward compatibility)
# SUPABASE_URL=https://your-project-id.supabase.co
# SUPABASE_KEY=your-anon-or-service-role-key-here

# Optional: Performance tuning
# SCRAPER_THREAD_COUNT=4
# SCRAPER_BATCH_SIZE=100
# SCRAPER_REQUEST_DELAY=2

# Copy this file to .env and fill in your real values.
# NEVER commit .env — it is gitignored.

# ── Server-side only (never expose to browser) ────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

GEMINI_API_KEY=your_gemini_api_key_here
FOURSQUARE_API_KEY=your_foursquare_api_key_here   # optional

# ── Client-side (safe to expose — anon key only, NOT service role) ─────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
