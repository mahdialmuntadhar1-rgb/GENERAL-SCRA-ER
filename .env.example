# GENERAL-SCRA-ER (internal scraper app) environment template
#
# This repository is the ONLY active scraper frontend/dashboard.
# It must connect only to scraper/internal Supabase tables.
# Do NOT point these values to the public-app-only (belive) database config.

# Required (preferred explicit names)
SCRAPER_SUPABASE_URL=https://your-scraper-project-ref.supabase.co
SCRAPER_SUPABASE_KEY=your_scraper_supabase_anon_or_service_role_key

# Legacy fallback names (supported for compatibility; avoid in new setup)
# SUPABASE_URL=https://your-scraper-project-ref.supabase.co
# SUPABASE_KEY=your_scraper_supabase_anon_or_service_role_key
